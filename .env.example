# DRIFT configuration — copy to .env (or export in your shell)

# "mock" runs the whole pipeline with deterministic local stand-ins (no keys needed).
# "live" calls a real OpenAI-compatible endpoint (Fireworks / vLLM on AMD Cloud).
DRIFT_LLM_MODE=mock

# Live mode only: any OpenAI-compatible /chat/completions endpoint.
DRIFT_LLM_BASE_URL=https://api.fireworks.ai/inference/v1
DRIFT_LLM_API_KEY=

# Optional per-seat model overrides (defaults are Fireworks serverless Qwen3):
# DRIFT_MODEL_SCORER=accounts/fireworks/models/qwen3-30b-a3b
# DRIFT_MODEL_JUDGE=accounts/fireworks/models/qwen3-235b-a22b
# DRIFT_MODEL_PROSECUTOR= / DRIFT_MODEL_DEFENSE= / DRIFT_MODEL_VOICE=

# Ledger. SQLite for local dev; docker-compose provides postgres in deployment.
DATABASE_URL=sqlite:///drift.db

# Optional: where ALERT/countdown messages get POSTed (Slack incoming webhook etc.)
DRIFT_WEBHOOK_URL=
